PORT=3000
NODE_ENV=development

# Telegram BotFather
TELEGRAM_BOT_TOKEN=
# 32+ ký tự ngẫu nhiên, chỉ gồm A-Z a-z 0-9 _ -
TELEGRAM_WEBHOOK_SECRET=
# Bắt buộc: user_id được phép, ngăn cách bởi dấu phẩy
TELEGRAM_ALLOWED_USER_IDS=
# Tuỳ chọn: nếu đặt thì chat_id cũng phải nằm trong danh sách này
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_PRIVATE_ONLY=true
TELEGRAM_TIME_ZONE=Asia/Ho_Chi_Minh

# Google Apps Script deployment /exec
APPS_SCRIPT_WEB_APP_URL=
# Phải giống Script Property TELEGRAM_APPS_SCRIPT_SECRET, tối thiểu 32 ký tự
TELEGRAM_APPS_SCRIPT_SECRET=
APPS_SCRIPT_TIMEOUT_MS=330000

# Chỉ dùng khi chạy npm run telegram:set-webhook
PUBLIC_BASE_URL=https://your-service.example.com
# Chỉ đặt true khi chủ động muốn xóa toàn bộ Telegram backlog
TELEGRAM_DROP_PENDING_UPDATES=false
